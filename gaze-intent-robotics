    "class IntentionNet(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(128 + 64, 128),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(128, 2)  # gaze (x, y)\n",
    "        )\n",
    "    \n",
    "    def forward(self, img, txt):\n",
    "        x = torch.cat([img, txt], dim=-1)\n",
    "        return self.net(x)"
   ]
