    "class VLIA(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.intention_net = IntentionNet()\n",
    "        self.action_net = ActionNet()\n",
    "    \n",
    "    def forward(self, img, txt):\n",
    "        intention = self.intention_net(img, txt)\n",
    "        action = self.action_net(img, txt, intention)\n",
    "        return intention, action"
   ]
