    "class SyntheticDataset(torch.utils.data.Dataset):\n",
    "    def __init__(self, n_samples=10000):\n",
    "        self.n = n_samples\n",
    "        \n",
    "        # Vision features (like CNN output)\n",
    "        self.images = torch.randn(n_samples, 128)\n",
    "        \n",
    "        # Language embeddings\n",
    "        self.text = torch.randn(n_samples, 64)\n",
    "        \n",
    "        # Intention (gaze point: x, y)\n",
    "        self.intentions = torch.randn(n_samples, 2)\n",
    "        \n",
    "        # Actions (robot control vector)\n",
    "        self.actions = torch.randn(n_samples, 8)\n",
    "\n",
    "    def __len__(self):\n",
    "        return self.n\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        return (\n",
    "            self.images[idx],\n",
    "            self.text[idx],\n",
    "            self.intentions[idx],\n",
    "            self.actions[idx]\n",
    "        )\n",
    "\n",
    "dataset = SyntheticDataset()\n",
    "dataloader = torch.utils.data.DataLoader(dataset, batch_size=64, shuffle=True)"
   ]
