    "class ActionNet(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(128 + 64 + 2, 128),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(128, 8)\n",
    "        )\n",
    "    \n",
    "    def forward(self, img, txt, intention):\n",
    "        x = torch.cat([img, txt, intention], dim=-1)\n",
    "        return self.net(x)"
