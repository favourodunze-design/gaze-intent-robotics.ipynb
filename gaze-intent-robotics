    "for epoch in range(5):\n",
    "    total_loss = 0\n",
    "    \n",
    "    for img, txt, intent_gt, action_gt in dataloader:\n",
    "        pred_intent, pred_action = model(img, txt)\n",
    "        \n",
    "        loss_intent = criterion_intent(pred_intent, intent_gt)\n",
    "        loss_action = criterion_action(pred_action, action_gt)\n",
    "        \n",
    "        # Weighted loss (paper uses λ weighting)\n",
    "        loss = loss_action + 0.1 * loss_intent\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        \n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    print(f\"Epoch {epoch+1}, Loss: {total_loss:.4f}\")"
   ]
